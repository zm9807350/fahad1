{
  "version": 2,
  "builds": [
    { "src": "*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/waqar", "dest": "/waqar.js" },
    { "src": "/kashif", "dest": "/kashif.js" },
    { "src": "/Ramzan", "dest": "/Ramzan.js" },
    { "src": "/Tarif", "dest": "/Tarif.js" },
    { "src": "/maqsood", "dest": "/maqsood.js" },
    { "src": "/Rafique", "dest": "/Rafique.js" },
    { "src": "/Sanaulah", "dest": "/Sanaulah.js" },
    { "src": "/bisharat", "dest": "/bisharat.js" }
  ]
}
